# Apex URL of this MCP deployment, no path, no trailing slash. Every bridge
# (currently /notion, future /strava etc.) is served under this host. Each
# bridge appends its own path locally.
# Examples:
#   https://mcp.kincaidoneil.com
#   https://my-mcp-bridge.vercel.app
PUBLIC_BASE_URL=http://localhost:3000

# 32-byte secret for HMAC signing + AES-GCM key wrap of all OAuth artifacts.
# Generate with: openssl rand -base64 32
# Rotating this invalidates ALL outstanding tokens (your global revocation primitive).
JWT_SIGNING_KEY=

# ---- Notion bridge (/notion) ----

# Notion OAuth integration credentials (https://www.notion.so/profile/integrations)
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=

# Allowlist — at least one of these MUST be set, or the server refuses to start.
# Email is preferred (requires the Notion integration to have the
# "user information including email addresses" capability enabled).
ALLOWED_NOTION_EMAILS=
ALLOWED_NOTION_WORKSPACE_IDS=
